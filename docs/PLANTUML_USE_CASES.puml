title Deployment Diagram - Kiến Trúc Triển Khai Cloud BETTER

node "Developer Machine\n(Windows)" as DEV {
  artifact "VS Code\nSource Code" as SRC
  component "Docker Desktop" as DOCKER
}

node "GitHub" as GH {
  artifact "Repository\n(main branch)" as REPO
  component "GitHub Actions\nCI Pipeline" as CI
}

node "Vercel CDN\n(Global Edge)" as VERCEL {
  component "Nginx:alpine\nStatic Server" as NGINX
  artifact "React Build\n/dist (HTML/CSS/JS)" as BUILD
}

node "Render.com\n(US East)" as RENDER {
  component "Node.js 18\nExpress API" as NODE
  artifact "server.js\nREST API :5000" as API
}

database "MongoDB Atlas\nCluster0 (Cloud)" as MONGO {
  artifact "Products\nPosts\nReviews\nUsers" as COLL
}

node "End User\nBrowser" as CLIENT

' -- Connections --
SRC --> REPO : git push\n(HTTPS)
REPO --> CI  : trigger on push
CI --> VERCEL : Auto deploy\n(on CI pass)
CI --> RENDER : Auto deploy\n(on CI pass)

NGINX --> BUILD : serves
NODE --> API    : runs

VERCEL --> RENDER : HTTPS REST API calls\n(CORS enabled)
RENDER --> MONGO  : Mongoose / TLS\nmongodb+srv://

CLIENT --> VERCEL : HTTPS :443\nbetter.vercel.app
@enduml

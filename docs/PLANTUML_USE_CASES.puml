' ============================================================
' FILE 4: SEQUENCE DIAGRAM - LUỒNG ĐĂNG NHẬP JWT
' ============================================================
@startuml SEQ_LOGIN
skinparam backgroundColor #0f1117
skinparam sequence {
  ArrowColor #3b82f6
  ActorBorderColor #a855f7
  LifeLineBorderColor #3b82f6
  ParticipantBackgroundColor #1a1d27
  ParticipantBorderColor #3b82f6
  ParticipantFontColor #e2e8f0
  ActorFontColor #e2e8f0
  NoteBorderColor #a855f7
  NoteBackgroundColor #1a1d27
  NoteFontColor #e2e8f0
}
skinparam ArrowFontColor #e2e8f0

title Sequence Diagram - Luồng Đăng Nhập JWT

actor "Người Dùng" as User
participant "React\nFrontend" as FE
participant "Express\nBackend" as BE
database "MongoDB\nAtlas" as DB

User -> FE : Nhập Email + Password\nnhấn Đăng Nhập
FE -> BE : POST /api/auth/login\n{ email, password }
BE -> DB : User.findOne({ email })
DB --> BE : Trả về User document
alt Không tìm thấy Email
  BE --> FE : 400 { error: "Tài khoản không tồn tại" }
  FE --> User : Hiển thị thông báo lỗi
else Email tồn tại
  BE -> BE : bcrypt.compare(password, user.password)
  alt Mật khẩu SAI
    BE --> FE : 400 { error: "Mật khẩu sai" }
    FE --> User : Hiển thị lỗi mật khẩu
  else Mật khẩu ĐÚNG
    BE -> BE : jwt.sign({ _id, role }, JWT_SECRET)
    BE --> FE : 200 { token, user }
    FE -> FE : localStorage.setItem("token", token)
    FE --> User : Cập nhật UI\nHiện Avatar & Tên
  end
end

note over FE, BE
  Request tiếp theo có xác thực:
  Header: Authorization: Bearer <token>
end note

User -> FE : Thực hiện hành động\n(Bình luận, Wishlist...)
FE -> BE : Request + { Authorization: Bearer <token> }
BE -> BE : authMiddleware:\njwt.verify(token, secret)
alt Token hợp lệ
  BE -> DB : Xử lý nghiệp vụ
  DB --> BE : Kết quả
  BE --> FE : 200 OK + Data
  FE --> User : Cập nhật giao diện
else Token không hợp lệ
  BE --> FE : 401 Unauthorized
  FE --> User : Yêu cầu đăng nhập lại
end
@enduml


' ============================================================
' FILE 5: ACTIVITY DIAGRAM - LUỒNG SO SÁNH ĐA THIẾT BỊ
' ============================================================
@startuml ACT_COMPARE
skinparam backgroundColor #0f1117
skinparam activity {
  BackgroundColor #1a1d27
  BorderColor #3b82f6
  FontColor #e2e8f0
  DiamondBackgroundColor #1a1d27
  DiamondBorderColor #a855f7
  DiamondFontColor #e2e8f0
  StartColor #3b82f6
  EndColor #a855f7
  ArrowColor #3b82f6
}
skinparam ArrowFontColor #e2e8f0

title Activity Diagram - Luồng So Sánh Đa Thiết Bị

start

:Người dùng vào tab "So Sánh";
:Hệ thống fetch GET /api/products;
:Hiển thị 2 Dropdown chọn sản phẩm;

:Người dùng chọn Thiết Bị 1;
:Người dùng chọn Thiết Bị 2;

:CompareSection tính chartData;
:Render Radar Chart 2 lớp\n(Xanh & Đỏ);
:Render Bảng Thông Số 2 cột;

repeat
  if (Muốn thêm thiết bị?) then (Có)
    if (Đã đủ 4 thiết bị?) then (Có)
      :Ẩn nút "+"\nHiện thông báo giới hạn;
    else (Chưa)
      :Hiện Dropdown mới;
      :Người dùng chọn Thiết Bị mới;
      :Cập nhật Radar + Bảng;
    endif
  else (Không)
  endif

  if (Muốn xóa thiết bị?) then (Có)
    if (Còn ≤ 2 thiết bị?) then (Có)
      :Ẩn nút "✕"\nGiữ tối thiểu 2;
    else (Không)
      :Xóa thiết bị đã chọn;
      :Cập nhật Radar + Bảng;
    endif
  else (Không)
  endif
repeat while (Tiếp tục điều chỉnh?) is (Có)
->Không;

if (Muốn tư vấn AI?) then (Có)
  :Nhấn "Hỏi Nhận Xét Từ AI";
  :AI phân tích danh sách\nthiết bị đang so sánh;
  :Hiển thị kết quả Markdown;
else (Không)
endif

if (Muốn mua ngay?) then (Có)
  :Nhấn "MUA NGAY →";
  :Mở tab Shopee / TikTok;
else (Không)
endif

stop
@enduml


' ============================================================
' FILE 6: CLASS DIAGRAM - MÔ HÌNH DỮ LIỆU MONGODB
' ============================================================
@startuml CLASS_DB
skinparam backgroundColor #0f1117
skinparam class {
  BackgroundColor #1a1d27
  BorderColor #3b82f6
  FontColor #e2e8f0
  HeaderBackgroundColor #3b82f6
  HeaderFontColor #ffffff
  AttributeFontColor #e2e8f0
}
skinparam ArrowColor #a855f7
skinparam ArrowFontColor #e2e8f0

title Class Diagram - Mô Hình Dữ Liệu MongoDB (Mongoose Schema)

class Product {
  + _id : ObjectId <<PK>>
  + id : String <<Unique>>
  + name : String <<NotNull>>
  + brand : String <<NotNull>>
  + price : String
  + priceValue : Number
  + category : String
  + image : String
  + specs : Mixed <<JSON>>
  + isFeatured : Boolean = false
  + links : Object
  + createdAt : Date
  + updatedAt : Date
  --
  + getRadarScore() : Object
}

class User {
  + _id : ObjectId <<PK>>
  + email : String <<Unique, NotNull>>
  + password : String <<bcrypt hashed>>
  + displayName : String
  + photoURL : String
  + points : Number = 0
  + wishlist : String[]
  + role : String = "User"
  + createdAt : Date
  + updatedAt : Date
}

class Review {
  + _id : ObjectId <<PK>>
  + productId : String <<FK→Product.id>>
  + userId : ObjectId <<FK→User._id>>
  + userName : String
  + userPhoto : String
  + text : String <<NotNull>>
  + createdAt : Date
  + updatedAt : Date
}

class Post {
  + _id : ObjectId <<PK>>
  + id : String <<Unique>>
  + title : String <<NotNull>>
  + summary : String
  + content : String <<Markdown>>
  + image : String
  + date : String
  + createdAt : Date
  + updatedAt : Date
}

class Specs <<JSON Object>> {
  + releaseDate : String
  + weight : String
  + materials : String
  + screen : String
  + chip : String
  + ram : String
  + storage : String
  + camera : String
  + battery : String
  + os : String
}

' -- Relationships --
Product "1" --> "0..*" Review : productId
User "1" --> "0..*" Review : userId
Product "1" *-- "1" Specs : embedded
User "0..*" --> "0..*" Product : wishlist[]

note right of User
  role = "User"  → Thành Viên
  role = "Admin" → Quản Trị Viên
end note

note bottom of Specs
  Trường specs dùng Mixed type
  để linh hoạt giữa Phone & Laptop
end note
@enduml


